<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/diamond_black"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/settings_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="@style/TextAppearance.DiamondRP.Headline"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="12dp" />

        <!-- Tema -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/itemTheme"
            style="@style/Widget.DiamondRP.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_theme" android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/settings_theme"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                <TextView
                    android:id="@+id/txtThemeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Caption"
                    android:layout_marginEnd="6dp" />

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:contentDescription="@null" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Idioma -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/itemLanguage"
            style="@style/Widget.DiamondRP.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/itemTheme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_language" android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/settings_language"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                <TextView
                    android:id="@+id/txtLanguageValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Caption"
                    android:layout_marginEnd="6dp" />

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:contentDescription="@null" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Limpar cache -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/itemClearCache"
            style="@style/Widget.DiamondRP.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/itemLanguage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_cache" android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/settings_clear_cache"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                <TextView
                    android:id="@+id/txtCacheSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Caption" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Verificar atualização -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/itemCheckUpdate"
            style="@style/Widget.DiamondRP.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/itemClearCache"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_update" android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/settings_check_update"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                <ProgressBar
                    android:id="@+id/progressCheckUpdate"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sobre / Info do app -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/itemAbout"
            style="@style/Widget.DiamondRP.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/itemCheckUpdate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_info" android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/settings_app_info"
                    android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" android:contentDescription="@null" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

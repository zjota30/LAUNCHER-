<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/diamond_black">

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main"
        android:alpha="0.35"
        android:contentDescription="@null" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Topo: logo + ícone de configurações -->
            <ImageView
                android:id="@+id/imgLogoSmall"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_diamond_logo"
                android:contentDescription="@string/app_name"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_settings"
                android:contentDescription="@string/settings_title"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Card de status do servidor -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardServerStatus"
                style="@style/Widget.DiamondRP.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/imgLogoSmall"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/dotStatus"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_online" />

                    <TextView
                        android:id="@+id/txtServerName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Diamond RP"
                        android:textAppearance="@style/TextAppearance.DiamondRP.Body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPlayersOnline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/0"
                        android:textAppearance="@style/TextAppearance.DiamondRP.Body" />

                    <TextView
                        android:id="@+id/txtPing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="-- ms"
                        android:textAppearance="@style/TextAppearance.DiamondRP.Caption" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notícias -->
            <TextView
                android:id="@+id/txtNewsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_news"
                android:textAppearance="@style/TextAppearance.DiamondRP.Body"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/cardServerStatus"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNews"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/txtNewsHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Redes sociais -->
            <LinearLayout
                android:id="@+id/layoutSocials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/rvNews"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageButton
                    android:id="@+id/btnDiscord"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_button"
                    android:src="@drawable/ic_discord"
                    android:contentDescription="@string/social_discord" />

                <ImageButton
                    android:id="@+id/btnInstagram"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_button"
                    android:src="@drawable/ic_instagram"
                    android:contentDescription="@string/social_instagram" />

                <ImageButton
                    android:id="@+id/btnWhatsapp"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_button"
                    android:src="@drawable/ic_whatsapp"
                    android:contentDescription="@string/social_whatsapp" />

            </LinearLayout>

            <!-- Campo de nickname -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNickname"
                style="@style/Widget.DiamondRP.EditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="@string/hint_nickname"
                app:layout_constraintTop_toBottomOf="@id/layoutSocials"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtNickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLength="24"
                    android:singleLine="true"
                    android:textColor="@color/diamond_white" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botão JOGAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                style="@style/Widget.DiamondRP.Button.Play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_play"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:layout_constraintTop_toBottomOf="@id/tilNickname"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="v1.0.0"
                android:textAppearance="@style/TextAppearance.DiamondRP.Caption"
                app:layout_constraintTop_toBottomOf="@id/btnPlay"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

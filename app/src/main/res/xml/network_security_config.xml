<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Por padrão, apenas HTTPS é permitido. Caso seu servidor de config/CDN
         só tenha HTTP disponível, adicione um <domain-config> com
         cleartextTrafficPermitted="true" apontando para o domínio específico,
         em vez de liberar tudo globalmente. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
